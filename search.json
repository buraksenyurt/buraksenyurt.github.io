---
layout: null
---
[
  {%- for post in site.posts -%}
    {%- assign taxonomy_entry = site.data.inferred_taxonomy.posts[post.url] -%}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | relative_url | jsonify }},
      "date": {{ post.date | date: site.minima.date_format | jsonify }},
      "excerpt": {{ post.excerpt | markdownify | strip_html | strip_newlines | jsonify }},
      "content": {{ post.content | markdownify | strip_html | strip_newlines | jsonify }},
      "tags": {{ taxonomy_entry.tags | default: post.tags | jsonify }},
      "categories": {{ taxonomy_entry.categories | default: post.categories | jsonify }}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]